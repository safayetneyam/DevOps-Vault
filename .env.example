# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# --- PostgreSQL ---
POSTGRES_DB=vault
POSTGRES_USER=vault
POSTGRES_PASSWORD=change-me-in-production
DB_HOST=db
DB_PORT=5432

# --- Vault write-protection ---
# Plain-text password shared by every mutation surface (create, edit,
# single/batch delete, bulk-rename-tool, bulk-delete-tool). The app
# only ever sees VAULT_PASSWORD_HASH — the PBKDF2-SHA256 hash of this
# value with a fixed salt. Both are required to live here so the
# container can boot without code changes.
#
# To rotate: change VAULT_PASSWORD to a new value and re-run:
#   python -c "import hashlib,base64; \
#     print(base64.b64encode(hashlib.pbkdf2_hmac('sha256', \
#       b'YOUR_NEW_PASSWORD', b'vault-salt-v1', 200000)).decode())"
# then paste the output below.
VAULT_PASSWORD=change-me-in-production
VAULT_PASSWORD_HASH=jcfjD6Dzg+h+2K50HFWpYUZuRNgMaBeVWkzKvKaVB5c=